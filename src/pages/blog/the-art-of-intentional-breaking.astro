    const currentLang = localStorage.getItem("lang") === "id" ? "id" : "en";
    if (typeof window.__applyBlogLang === "function")
        window.__applyBlogLang(currentLang);

    // Reading progress bar
    const progressBar = document.getElementById(
        "scroll-progress"
    ) as HTMLElement;
    window.addEventListener(
        "scroll",
        () => {
            const h =
                document.documentElement.scrollHeight - window.innerHeight;
            if (progressBar)
                progressBar.style.width = `${
                    h > 0 ? (window.scrollY / h) * 100 : 0
                }%`;
        },
        { passive: true }
    );
